# OpenAI API key for embeddings + agents
OPENAI_API_KEY=sk-...

# ChromaDB persistence directory (default: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# ─── Multi-Agent System ───────────────────────────────────────────────────────

# LLM provider for agents: openai | anthropic | ollama
AGENT_PROVIDER=openai

# Architect agent model
ARCHITECT_MODEL=gpt-4o

# Engineer agent model
ENGINEER_MODEL=gpt-4o

# Validator agent model
VALIDATOR_MODEL=gpt-4o

# OpenAI-compatible base URL (for proxies / custom endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API key (if AGENT_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-...

# Ollama base URL (if AGENT_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Max iteration loops (Engineer ↔ Validator)
AGENT_MAX_ITERATIONS=3

# Timeout per agent call in seconds
AGENT_TIMEOUT_SECONDS=60
